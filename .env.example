# ============================================
# 中国旅游推荐问答系统 — 环境变量配置
# 复制此文件为 .env 并填写实际值
# ============================================

# --- 数据库 ---
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./tourism.db
# 生产环境切换到 PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tourism

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- 通义千问 (DashScope) ---
DASHSCOPE_API_KEY=sk-your-api-key-here

# --- JWT ---
JWT_SECRET=change-this-to-a-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- 高德地图 ---
AMAP_API_KEY=your-amap-api-key-here
AMAP_BASE_URL=https://restapi.amap.com/v3

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_data

# --- 应用 ---
APP_NAME=旅伴 - 中国旅游推荐助手
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# --- 管理员初始账号 ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
